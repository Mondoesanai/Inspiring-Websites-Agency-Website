<section class="section-italy" aria-label="{{ section.settings.heading }}">
  <div class="container">
    <div class="italy-grid">

      <!-- Image side -->
      <div class="italy-img-zone fade-up">
        {%- if section.settings.image -%}
          <img src="{{ section.settings.image | img_url: '1000x' }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy" width="1000" height="1250" />
        {%- else -%}
          <div class="italy-img-ph">
            <span>Italian Craftsmanship Photo<br/>Upload in Shopify Customizer</span>
          </div>
        {%- endif -%}
        <div class="italy-img-frame" aria-hidden="true"></div>
      </div>

      <!-- Copy side -->
      <div class="italy-copy">
        <p class="italy-eyebrow fade-up">{{ section.settings.eyebrow }}</p>
        <h2 class="italy-title fade-up d1">{{ section.settings.heading }}</h2>
        <p class="italy-body fade-up d2">{{ section.settings.body }}</p>

        <div class="italy-badges fade-up d3">
          {%- for block in section.blocks -%}
            {%- if block.type == 'badge' -%}
              <div class="italy-badge" {{ block.shopify_attributes }}>
                <span class="italy-badge-icon">{{ block.settings.icon }}</span>
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <div class="fade-up d4 btn-magnetic" style="display:inline-block;">
            <a href="{{ section.settings.cta_url }}" class="btn-primary">{{ section.settings.cta_text }}</a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Made in Italy",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)",  "default": "🇮🇹"                        },
        { "type": "text", "id": "text", "label": "Badge Text",    "default": "100% Certified Made in Italy" }
      ]
    }
  ],
  "settings": [
    { "type": "image_picker", "id": "image",    "label": "Craftsmanship Image"                                              },
    { "type": "text",         "id": "eyebrow",  "label": "Eyebrow",  "default": "Artisan Heritage"                          },
    { "type": "text",         "id": "heading",  "label": "Heading",  "default": "Handcrafted in Italy"                      },
    { "type": "textarea",     "id": "body",     "label": "Body",     "default": "These custom shoes are handmade by master Italian craftsmen from pristine Italian leather. Each designer pair is a one-of-a-kind, combining handcrafting tradition, quality and modern style for a product that's perfectly Italian." },
    { "type": "text",         "id": "cta_text", "label": "Button Text", "default": "Explore the Craft"                      },
    { "type": "url",          "id": "cta_url",  "label": "Button URL"                                                       }
  ],
  "presets": [
    {
      "name": "Made in Italy",
      "blocks": [
        { "type": "badge", "settings": { "icon": "🇮🇹", "text": "100% Certified Made in Italy"        } },
        { "type": "badge", "settings": { "icon": "✦",   "text": "Custom Crafted — Limited Edition"    } },
        { "type": "badge", "settings": { "icon": "✈",   "text": "Free Shipping: USA · CAN · EU"       } },
        { "type": "badge", "settings": { "icon": "★",   "text": "100% Satisfaction Guaranteed"        } }
      ]
    }
  ]
}
{% endschema %}
