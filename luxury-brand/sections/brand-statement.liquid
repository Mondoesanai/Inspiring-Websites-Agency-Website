<section class="section-brand" aria-label="{{ section.settings.heading | escape }}">

  <!-- Ambient glow -->
  <div aria-hidden="true" style="
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:700px;height:400px;
    background:radial-gradient(ellipse, rgba(200,169,126,0.07) 0%, transparent 65%);
    pointer-events:none;">
  </div>

  <div class="container" style="max-width:800px;position:relative;">

    <p class="rule-gold fade-up" style="justify-content:center;margin-bottom:36px;">
      {{ section.settings.eyebrow }}
    </p>

    <h2 class="brand-quote fade-up d1">
      {{ section.settings.quote | newline_to_br }}
    </h2>

    <div class="divider fade-up d2" style="margin-bottom:36px;"></div>

    <p class="brand-body fade-up d3">
      {{ section.settings.body }}
    </p>

    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn-ghost fade-up d4">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Brand Statement",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Notre Maison"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Pull Quote (use newline for line 2 in italic gold)",
      "default": "\"Luxury is not a necessity\nto me — it is an art.\""
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "Born from an obsession with perfection, Lumière exists for those who demand more from the world — and receive it. Each piece a collaboration between master artisans and the finest materials on earth."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Discover the Maison"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    { "name": "Brand Statement" }
  ]
}
{% endschema %}
