<footer id="contact" aria-label="Footer">
  <div class="container">

    <div class="footer-grid">

      <!-- Brand column -->
      <div>
        <a href="{{ routes.root_url }}" class="logo">
          {{ settings.logo_text | default: shop.name }}<em>.</em>
        </a>
        <p class="footer-tagline">{{ section.settings.tagline }}</p>
      </div>

      <!-- Link columns from blocks -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="footer-col-title">{{ block.settings.heading }}</h4>
            <ul class="footer-links">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}" class="footer-link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    <!-- Footer bottom -->
    <div class="footer-bottom">
      <p class="footer-copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>

      <div class="footer-social">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <span>·</span>
          <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">Pinterest</a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <span>·</span>
          <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>
        {%- endif -%}
      </div>

      <p class="footer-credit">Designed with intention</p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "blocks": [
    {
      "type": "link_list",
      "name": "Link Column",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Column Heading", "default": "Collections" },
        { "type": "link_list", "id": "menu",    "label": "Menu"                                      }
      ]
    }
  ],
  "settings": [
    { "type": "textarea", "id": "tagline",       "label": "Brand Tagline",  "default": "A house built on the belief that beauty, at its most refined, transcends adornment." },
    { "type": "url",      "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url",      "id": "pinterest_url", "label": "Pinterest URL"  },
    { "type": "url",      "id": "tiktok_url",    "label": "TikTok URL"     }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Collections" } },
        { "type": "link_list", "settings": { "heading": "Maison"      } },
        { "type": "link_list", "settings": { "heading": "Client Care"  } }
      ]
    }
  ]
}
{% endschema %}
